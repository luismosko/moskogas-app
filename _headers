# Cloudflare Pages — Cache Control
# HTML: sempre busca versão nova no servidor
/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Raiz do site também
/
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# JS compartilhado (shared.js): sem cache — muda junto com as páginas
/shared.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Assets estáticos (imagens, ícones): podem cachear por 1 semana
/*.png
  Cache-Control: public, max-age=604800
/*.ico
  Cache-Control: public, max-age=604800
/*.svg
  Cache-Control: public, max-age=604800
