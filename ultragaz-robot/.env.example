# MoskoGás API — Robô Ultragaz
# Copie este arquivo para .env e preencha os valores

# URL da API MoskoGás
MOSKOGAS_API_URL=https://api.moskogas.com.br

# APP_API_KEY do Cloudflare (secret APP_API_KEY do worker)
MOSKOGAS_API_KEY=sua_app_api_key_aqui

# As credenciais do Hub Ultragaz ficam no painel config.html
# O robô busca automaticamente via GET /api/ultragaz/config
# Não precisa colocar login/senha aqui!

# Intervalo de renovação da sessão Playwright (em ms) — padrão 6h
SESSION_RENEWAL_MS=21600000

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Gmail IMAP — para leitura do código 2FA do Hub Ultragaz
GMAIL_USER=luismosko@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
